# PF_WEBLOGS endpoint mapping to consolidated backend implementation
# This file is enabled/disabled dynamically by the lighttpd s6 script.

alias.url += (
  "/cgi/logs.sh" => "/usr/share/planefence/logs.sh"
)

$HTTP["url"] =~ "^/cgi/logs\.sh$" {
  cgi.assign = ( ".sh" => "/bin/bash" )
  server.stream-response-body = 2
  setenv.add-response-header += (
    "Cache-Control" => "no-store",
    "X-Content-Type-Options" => "nosniff"
  )
}
