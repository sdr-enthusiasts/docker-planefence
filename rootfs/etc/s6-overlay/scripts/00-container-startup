#!/command/with-contenv bash
#shellcheck shell=bash disable=SC2015,SC1091,SC2154
# -----------------------------------------------------------------------------------
# Copyright 2020-2026 Ramon F. Kolb - licensed under the terms and conditions
# of GPLv3. The terms and conditions of this license are included with the Github
# distribution of this package, and are also available here:
# https://github.com/sdr-enthusiasts/planefence4docker/
#
# This package may incorporate other software and license terms.
# -----------------------------------------------------------------------------------
#
#sleep 1 # Give 00-container-start-time a chance to write the container start time to the file before we read it in pf-common
source /scripts/pf-common
if [[ -f /usr/share/planefence/persist/planefence.config ]]; then
    source /usr/share/planefence/persist/planefence.config
fi

PA_HISTTIME_MIGRATION_CUTOFF_EPOCH=1742929200
PA_HISTTIME_MIGRATION_TARGET_FILE="/usr/share/planefence/persist/planefence.config"

"${s6wrap[@]}" echo "Initial Planefence check..."

if [[ ! -f /usr/share/planefence/persist/planefence.config ]]; then
    /usr/share/planefence/prep-planefence.sh
fi

# Post message to any old plane-alert page to inform user that Planefence has been updated
if ! chk_enabled "$PA_SHOW_STALE_PAGE"; then
    if [[ -f /usr/share/planefence/html/plane-alert/index.html ]]; then
        # Move the index to index-old.html in case someone wants to refer to it.
        mv -f /usr/share/planefence/html/plane-alert/index.html /usr/share/planefence/html/plane-alert/index-old.html
        if ! grep -q "\!-- pa_updated --" /usr/share/planefence/html/plane-alert/index-old.html; then
            sed -i "s|</h1>|</h1><h2>IMPORTANT:<br>This page is no longer maintained. To see current Plane-Alert entries, click <a href=\"index.html\">here</a>.</h2><\!-- pa_updated -->|g" /usr/share/planefence/html/plane-alert/index-old.html
            sed -i "s|<hr>Note - soon.*<hr>||g" /usr/share/planefence/html/plane-alert/index-old.html
        else
            sed -i "s|</h1>.*<\!-- pa_updated -->|</h1><h2>IMPORTANT:<br>This page is no longer maintained. To see current Plane-Alert entries, click <a href=\"index.html\">here</a>.</h2><\!-- pa_updated -->|g" /usr/share/planefence/html/plane-alert/index-old.html
        fi
    fi
else
    # Restore the old page if it exists
    if [[ -f /usr/share/planefence/html/plane-alert/index-old.html ]]; then
        mv -f /usr/share/planefence/html/plane-alert/index-old.html /usr/share/planefence/html/plane-alert/index.html
        if ! grep -q "\!-- pa_updated --" /usr/share/planefence/html/plane-alert/index.html; then
            sed -i "s|</h1>|</h1><h2>IMPORTANT:<br>This page is no longer maintained. To see current Plane-Alert entries, click <a href=\"${PF_PA_LINK:-../index.html?mode=pa}\">here</a>.</h2><\!-- pa_updated -->|g" /usr/share/planefence/html/plane-alert/index.html
            sed -i "s|<hr>Note - soon.*<hr>||g" /usr/share/planefence/html/plane-alert/index.html
        else
            sed -i "s|</h1>.*<\!-- pa_updated -->|</h1><h2>IMPORTANT:<br>This page is no longer maintained. To see current Plane-Alert entries, click <a href=\"${PF_PA_LINK:-../index.html?mode=pa}\">here</a>.</h2><\!-- pa_updated -->|g" /usr/share/planefence/html/plane-alert/index.html
        fi        
    fi
fi

if chk_disabled "${PLANEFENCE:-$PF_PLANEFENCE}" && chk_disabled "${PLANEALERT:-$PF_PLANEALERT}"; then
    log_print ERR "(PF_)PLANEFENCE and (PF_)PLANEALERT are both disabled. Container will not start!"
    exec sleep infinity
fi

# Now update the plane-alert-candidates.txt file if needed
CANDIDATE_FILE="$(GET_PARAM pa PA_COLLECT_CANDIDATES_FILE || true)"
CANDIDATE_FILE="${CANDIDATE_FILE:-plane-alert-candidates.txt}"
CANDIDATE_FILE="/usr/share/planefence/persist/${CANDIDATE_FILE##*/}"
FIX_VERSION="v1.0"
if [[ -f "$CANDIDATE_FILE" && ! -f /usr/share/planefence/persist/.internal/.candidate_file_updated ]] \
   || [[ -f "$CANDIDATE_FILE" && -f /usr/share/planefence/persist/.internal/.candidate_file_updated && "$(</usr/share/planefence/persist/.internal/.candidate_file_updated)" != "$FIX_VERSION" ]]; then
    log_print INFO "Updating $CANDIDATE_FILE to add ImageLink column if missing or update existing ImageLink values if needed..."
    /scripts/update-pa-candidates.sh "$CANDIDATE_FILE"
    echo "$FIX_VERSION" > /usr/share/planefence/persist/.internal/.candidate_file_updated
fi

# One-time migration by mtime gate only: for legacy configs older than
# 2025-03-25 19:00:00 UTC, bump PA_HISTTIME from 14 to 30.
if [[ -f "$PA_HISTTIME_MIGRATION_TARGET_FILE" ]]; then
    file_mtime="$(stat -c %Y "$PA_HISTTIME_MIGRATION_TARGET_FILE" 2>/dev/null || printf '0')"
    pa_histtime_val="$(GET_PARAM base PA_HISTTIME || true)"
    pa_histtime_val="${pa_histtime_val//[[:space:]]/}"
    if [[ "$file_mtime" =~ ^[0-9]+$ ]] && (( file_mtime < PA_HISTTIME_MIGRATION_CUTOFF_EPOCH )) && [[ "$pa_histtime_val" == "14" ]]; then
        log_print INFO "Applying PA_HISTTIME migration (14 -> 30) for legacy planefence.config"
        sed -i -E 's|^([[:space:]]*(export[[:space:]]+)?)PA_HISTTIME[[:space:]]*=.*$|\1PA_HISTTIME=30|' "$PA_HISTTIME_MIGRATION_TARGET_FILE"
        touch -d "@$((PA_HISTTIME_MIGRATION_CUTOFF_EPOCH + 1))" "$PA_HISTTIME_MIGRATION_TARGET_FILE" 2>/dev/null || touch "$PA_HISTTIME_MIGRATION_TARGET_FILE" 2>/dev/null || true
    fi
fi

hist_days_for_mode() {
    local section="$1" val
    val="$(GET_PARAM "$section" HISTTIME || true)"
    val="${val//[[:space:]]/}"
    [[ "$val" =~ ^[0-9]+$ ]] || val=14
    (( val < 1 )) && val=14
    (( val > 120 )) && val=120
    printf '%s' "$val"
}

# Pre-warm historical insights cache in the background to make date switching snappy.
# We cap prewarm depth to avoid very long startup CPU bursts on large HISTTIME settings.
if [[ -x /usr/share/planefence/html/cgi/insights.sh ]]; then
    (
        sleep 8
        local_max_days=30

        if ! chk_disabled "${PLANEFENCE:-$PF_PLANEFENCE}"; then
            pf_days="$(hist_days_for_mode pf)"
            (( pf_days < local_max_days )) && pf_days=$local_max_days
            (( pf_days > local_max_days )) && pf_days=$local_max_days
            for (( day=1; day<pf_days; day++ )); do
                req_date="$(date -u -d "${day} day ago" +%y%m%d 2>/dev/null || true)"
                [[ "$req_date" =~ ^[0-9]{6}$ ]] || continue
                INSIGHTS_RAW=1 /usr/share/planefence/html/cgi/insights.sh "mode=planefence" "date=${req_date}" "days=${pf_days}" >/dev/null 2>&1 || true
            done
        fi

        if ! chk_disabled "${PLANEALERT:-$PF_PLANEALERT}"; then
            pa_days="$(hist_days_for_mode plane-alert)"
            (( pa_days < local_max_days )) && pa_days=$local_max_days
            (( pa_days > local_max_days )) && pa_days=$local_max_days
            for (( day=1; day<pa_days; day++ )); do
                req_date="$(date -u -d "${day} day ago" +%y%m%d 2>/dev/null || true)"
                [[ "$req_date" =~ ^[0-9]{6}$ ]] || continue
                INSIGHTS_RAW=1 /usr/share/planefence/html/cgi/insights.sh "mode=plane-alert" "date=${req_date}" "days=${pa_days}" >/dev/null 2>&1 || true
            done
        fi
    ) &
fi

"${s6wrap[@]}" echo "Initial Planefence check complete."
